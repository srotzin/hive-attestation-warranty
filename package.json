{
  "name": "@hivecivilization/hive-attestation-warranty",
  "version": "1.0.0",
  "description": "Attestation-as-Warranty: signed attestations with issuer stake, breach detection, and evidence validation — HiveAttest Claim C18 (USPTO 64/055,601).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "warranty",
    "attestation",
    "breach",
    "slash",
    "liability",
    "ed25519",
    "hive"
  ],
  "license": "Apache-2.0",
  "author": "Stephen A. Rotzin",
  "repository": {
    "type": "git",
    "url": "https://github.com/srotzin/hive-attestation-warranty.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@noble/ed25519": "^2.2.3",
    "@noble/hashes": "^1.7.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.1.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
